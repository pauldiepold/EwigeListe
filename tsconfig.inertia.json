{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "preserve",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["resources/js/inertia/*"]
    },
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": [
    "resources/js/inertia/**/*.ts",
    "resources/js/inertia/**/*.vue",
    "resources/js/inertia/types/**/*.d.ts",
    "auto-imports.d.ts",
    "components.d.ts"
  ]
}
